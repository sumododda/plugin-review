{
  "$schema": "review-policy-schema",
  "version": "1.0",
  "description": "Organizational policy for plugin security reviews. Subagents use these rules to flag violations.",

  "blocked_capabilities": {
    "_comment": "Categories of functionality that are not permitted. Subagents search for packages, imports, and code patterns that provide these capabilities.",
    "tunneling": {
      "reason": "Exposes internal services to the public internet, bypasses firewall controls",
      "packages": ["ngrok", "localtunnel", "bore-cli", "serveo", "pagekite", "teleconsole", "cloudflared"],
      "patterns": ["ngrok", "localtunnel", "bore.pub", "serveo.net", "pagekite.net", "localhost.run"]
    },
    "remote_shell": {
      "reason": "Provides remote code execution capability, common in backdoors",
      "packages": ["reverse-shell", "shell-reverse", "node-pty-prebuilt", "ssh2"],
      "patterns": ["reverse.shell", "bind.shell", "meterpreter", "netcat.*-e", "nc.*-e"]
    },
    "crypto_mining": {
      "reason": "Unauthorized compute resource usage",
      "packages": ["coinhive", "cryptonight", "xmrig", "minergate"],
      "patterns": ["stratum\\+tcp://", "coinhive", "cryptonight", "monero.*pool"]
    },
    "keystroke_logging": {
      "reason": "Captures user input without consent",
      "packages": ["keylogger", "iohook", "node-global-key-listener"],
      "patterns": ["keylog", "keystroke.*capture", "keyboard.*hook.*global"]
    },
    "screen_capture": {
      "reason": "Captures screen content without explicit user action",
      "packages": ["screenshot-desktop", "desktop-screenshot", "robotjs"],
      "patterns": ["screenshot.*silent", "screen.*capture.*background"]
    },
    "clipboard_exfiltration": {
      "reason": "Reads clipboard content without user-initiated action",
      "packages": [],
      "patterns": ["clipboard.*read.*interval", "clipboard.*watch", "clipboard.*monitor"]
    }
  },

  "blocked_licenses": {
    "_comment": "Licenses incompatible with proprietary enterprise distribution",
    "deny": [
      "AGPL-3.0-only",
      "AGPL-3.0-or-later",
      "SSPL-1.0",
      "EUPL-1.1",
      "EUPL-1.2",
      "OSL-3.0",
      "CPAL-1.0",
      "RPL-1.1",
      "RPL-1.5",
      "Watcom-1.0"
    ],
    "warn": [
      "GPL-3.0-only",
      "GPL-3.0-or-later",
      "GPL-2.0-only",
      "GPL-2.0-or-later",
      "LGPL-3.0-only",
      "LGPL-3.0-or-later",
      "MPL-2.0",
      "CC-BY-SA-4.0",
      "CDDL-1.0"
    ],
    "require_review": [
      "LGPL-2.1-only",
      "LGPL-2.1-or-later",
      "Artistic-2.0",
      "EPL-2.0",
      "CPL-1.0"
    ]
  },

  "blocked_network": {
    "_comment": "Domains and IPs that should never appear in plugin code",
    "exfiltration_services": [
      "*.ngrok.io", "*.ngrok-free.app",
      "*.serveo.net",
      "*.localtunnel.me",
      "*.bore.pub",
      "*.localhost.run",
      "*.loca.lt"
    ],
    "paste_and_drop_sites": [
      "pastebin.com",
      "paste.ee",
      "hastebin.com",
      "transfer.sh",
      "file.io",
      "0x0.st",
      "ix.io",
      "sprunge.us"
    ],
    "ip_logging_services": [
      "iplogger.org",
      "grabify.link",
      "iplogger.com",
      "blasze.tk",
      "catsnthings.fun"
    ],
    "known_c2_patterns": [
      "*.onion",
      "*.i2p",
      "raw.githubusercontent.com/*/main/payload",
      "discord.com/api/webhooks/*"
    ],
    "metadata_endpoints": [
      "169.254.169.254",
      "metadata.google.internal",
      "100.100.100.200"
    ]
  },

  "install_scripts": {
    "_comment": "Install hooks are not blocked but MUST be flagged for manual review. The subagent should read the script content and summarize what it does.",
    "flag_for_review": ["preinstall", "postinstall", "preuninstall", "postuninstall", "prepare", "prepublish"],
    "auto_deny_if": "script downloads and executes remote code (curl|bash, wget|sh, etc.)"
  },

  "dependency_limits": {
    "max_direct_dependencies": 50,
    "max_total_dependencies": 300,
    "_comment": "Flag if the dependency count is disproportionate to functionality"
  },

  "sensitive_paths": {
    "_comment": "File paths the plugin must never access",
    "deny": [
      "~/.ssh/",
      "~/.aws/",
      "~/.gnupg/",
      "~/.kube/config",
      "~/.docker/config.json",
      "~/.npmrc",
      "~/.pypirc",
      "~/.gitconfig",
      "~/.bash_history",
      "~/.zsh_history",
      "/etc/passwd",
      "/etc/shadow",
      "/etc/hosts",
      "~/.config/gh/",
      "~/.claude/"
    ]
  },

  "required_files": {
    "_comment": "Files that must exist in the repo for approval",
    "hard_requirement": ["LICENSE"],
    "soft_requirement": ["README.md", "SECURITY.md", "CHANGELOG.md"]
  }
}
